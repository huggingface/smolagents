# Contract Finder Agent v2 - Environment Configuration Template
# Copy this file to .env and fill in actual values for your deployment
# IMPORTANT: Never commit .env to version control - it contains secrets!

# ============================================================================
# Flask Configuration
# ============================================================================
FLASK_APP=run.py
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=your-secret-key-here-min-32-chars-for-production

# ============================================================================
# OpenAI Configuration (LLM & Embeddings)
# ============================================================================
# API Key for OpenAI (required for LLM and embeddings)
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI API base URL (optional, defaults to https://api.openai.com/v1)
OPENAI_API_BASE=https://api.openai.com/v1

# LLM Model selection
LLM_MODEL_NAME=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_INVOCATION_TIMEOUT=30

# Embedding model (used for semantic search)
EMBEDDING_MODEL_NAME=text-embedding-ada-002
EMBEDDING_DIMENSION=1536

# ============================================================================
# Database Configuration (AlloyDB / PostgreSQL)
# ============================================================================
# AlloyDB connection - primary database for contracts
DB_HOST=localhost
DB_PORT=5432
DB_NAME=contract_finder
DB_USER=postgres
DB_PASSWORD=postgres

# Optional: Full PostgreSQL connection string (overrides individual DB_* params)
# DB_CONNECTION_STRING=postgresql://user:password@host:5432/database_name

# Database pool configuration
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================================================
# Redis Configuration (optional, for session caching)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_SOCKET_TIMEOUT=5

# ============================================================================
# Agent Configuration
# ============================================================================
AGENT_NAME=ContractFinderAgent

# Contract retrieval settings
MAX_CONTRACT_IDS=50
MAX_CHUNKS_TO_USE=10
MAX_CONTRACTS_TO_RETURN=10

# Similarity and relevance settings
SIMILARITY_THRESHOLD=0.3
CONTEXT_THRESHOLD=0.85
FILTER_CITATION_THRESHOLD=90

# Response generation
GENERATE_RESPONSE_FROM_DOCS=true
FILTER_CITATIONS=false
SMART_RESPONSE_ADJUSTMENT=true

# ============================================================================
# Session Management
# ============================================================================
# Session table name in database
CONTEXT_TABLE=contract_retrieval_session

# Session timeout in seconds (1 hour = 3600)
SESSION_TIMEOUT=3600

# Maximum number of documents to store per session
MAX_SESSION_DOCUMENTS=100

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/contract_finder_agent.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=5000

# Gunicorn worker configuration
WORKERS=4
THREADS=2
WORKER_CLASS=gthread
WORKER_TIMEOUT=300
KEEP_ALIVE=2

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGINS=*
CORS_ALLOW_HEADERS=Content-Type,Authorization
CORS_ALLOW_METHODS=GET,POST,OPTIONS,PUT,DELETE
CORS_SUPPORTS_CREDENTIALS=true

# ============================================================================
# Security Configuration
# ============================================================================
# HTTPS Configuration (for production)
USE_HTTPS=false
SSL_CERT_FILE=/path/to/cert.pem
SSL_KEY_FILE=/path/to/key.pem

# Rate limiting (requests per minute)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_BURST=120

# API Key authentication (optional)
API_KEY_ENABLED=false
API_KEY=your-api-key-here

# ============================================================================
# Monitoring & Observability
# ============================================================================
ENABLE_METRICS=true
METRICS_PORT=8000

# Sentry (error tracking) - optional
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_SHOW_MORE_PAGINATION=true
ENABLE_CITATION_GENERATION=true
ENABLE_LLM_RESPONSE_GENERATION=true
ENABLE_QUERY_CACHING=false

# ============================================================================
# Database Management UI (pgAdmin)
# ============================================================================
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# ============================================================================
# Inference Service Configuration (if using custom embeddings)
# ============================================================================
INFERENCE_SERVICE_URL=http://localhost:8080
INFERENCE_SERVICE_API_KEY=
INFERENCE_TIMEOUT=30

# ============================================================================
# External Service Credentials (if applicable)
# ============================================================================
# GCS (Google Cloud Storage) for document backup
GCS_PROJECT_ID=
GCS_BUCKET_NAME=
GCS_KEY_FILE=/path/to/gcs-key.json

# AWS S3 for document backup
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ============================================================================
# Development & Testing
# ============================================================================
DEVELOPMENT_MODE=false
TEST_MODE=false
DUMMY_DATA_ENABLED=false

# ============================================================================
# Notes for Production Deployment
# ============================================================================
# 1. Change FLASK_ENV to 'production'
# 2. Generate a strong SECRET_KEY (use: python -c "import secrets; print(secrets.token_hex(32))")
# 3. Use HTTPS with valid SSL certificates
# 4. Store all secrets in AWS Secrets Manager, Azure Key Vault, or similar
# 5. Use managed database (AWS RDS, Google Cloud SQL, Azure Database)
# 6. Set appropriate rate limits and authentication
# 7. Enable monitoring with CloudWatch, Datadog, or similar
# 8. Configure autoscaling based on load
# 9. Use health check endpoints for load balancing
# 10. Enable VPC and security group restrictions

